{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Posts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Author": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "Content": {
      "type": "blocks",
      "required": true
    },
    "Category": {
      "type": "enumeration",
      "enum": [
        "Video Games",
        "Movies",
        "Fashion",
        "TV Shows "
      ]
    }
  }
}
